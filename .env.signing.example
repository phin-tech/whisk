# Code signing
APPLE_SIGNING_IDENTITY=Developer ID Application: Your Name (TEAMID)

# Required for CI signing. APPLE_CERTIFICATE is a base64-encoded .p12
# imported into a temporary keychain by scripts/ci-setup-macos-keychain.sh.
APPLE_CERTIFICATE=op://Mac Development/Roux Signing/apple_certificate_base64
APPLE_CERTIFICATE_PASSWORD=op://Mac Development/Roux Signing/apple_certificate_password

# Apple ID notarization credentials.
APPLE_ID=op://Mac Development/Roux Notarization/apple_id
APPLE_PASSWORD=op://Mac Development/Roux Notarization/app_specific_password
APPLE_TEAM_ID=op://Mac Development/Roux Notarization/team_id
